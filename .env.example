# Docker Compose reads this file when copied to .env.

# Mail settings used by the backend container.
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_gmail_app_password

# Production hosts such as Railway may block SMTP ports.
# Prefer an HTTPS transactional email provider in production.
BREVO_API_KEY=your_brevo_api_key
MAIL_FROM_EMAIL=your_verified_sender@example.com
MAIL_FROM_NAME=ViVuGo

# Optional AI settings for local experiments.
AI_API_KEY=your_openrouter_api_key
AI_MODEL=openai/gpt-4o-mini
