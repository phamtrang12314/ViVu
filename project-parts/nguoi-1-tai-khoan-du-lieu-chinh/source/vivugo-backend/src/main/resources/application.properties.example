spring.profiles.active=${SPRING_PROFILES_ACTIVE:aws}
server.port=${SERVER_PORT:8081}

spring.datasource.url=${DB_URL}
spring.datasource.username=${DB_USERNAME}
spring.datasource.password=${DB_PASSWORD}
spring.datasource.driver-class-name=org.postgresql.Driver
app.database.require-aws=${REQUIRE_AWS_DATABASE:true}

spring.jpa.hibernate.ddl-auto=${HIBERNATE_DDL_AUTO:update}
spring.jpa.show-sql=${JPA_SHOW_SQL:false}
spring.jpa.properties.hibernate.format_sql=true

jwt.secret-key=${JWT_SECRET_KEY:replace-with-a-long-random-secret}
jwt.expiration-ms=${JWT_EXPIRATION_MS:86400000}
jwt.customer.secret-key=${JWT_CUSTOMER_SECRET_KEY:replace-with-a-long-random-customer-secret}
jwt.admin.secret-key=${JWT_ADMIN_SECRET_KEY:replace-with-a-long-random-admin-secret}

ai.api.key=${AI_API_KEY:your_openrouter_api_key}
ai.api.url=${AI_API_URL:https://openrouter.ai/api/v1/chat/completions}
ai.model=${AI_MODEL:openai/gpt-5.4-mini}
ai.admin.model=${AI_ADMIN_MODEL:openai/gpt-5.5}

spring.mail.host=${MAIL_HOST:smtp.gmail.com}
spring.mail.port=${MAIL_PORT:587}
spring.mail.username=${MAIL_USERNAME:${EMAIL_USER:your_email@gmail.com}}
spring.mail.password=${MAIL_PASSWORD:${EMAIL_PASS:your_app_password}}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true
spring.mail.properties.mail.smtp.ssl.trust=smtp.gmail.com

spring.servlet.multipart.max-file-size=${SPRING_MULTIPART_MAX_FILE_SIZE:50MB}
spring.servlet.multipart.max-request-size=${SPRING_MULTIPART_MAX_REQUEST_SIZE:50MB}

spring.cache.type=${SPRING_CACHE_TYPE:simple}
spring.data.redis.host=${SPRING_DATA_REDIS_HOST:localhost}
spring.data.redis.port=${SPRING_DATA_REDIS_PORT:6379}
spring.data.redis.repositories.enabled=false
management.health.redis.enabled=${MANAGEMENT_HEALTH_REDIS_ENABLED:false}
management.health.mail.enabled=false
management.endpoint.health.show-details=always

app.cors.allowed-origin-patterns=${CORS_ALLOWED_ORIGIN_PATTERNS:http://localhost:*,http://127.0.0.1:*}
app.asset-fallback-base-url=${ASSET_FALLBACK_BASE_URL:http://localhost:5173}
app.rate-limit.enabled=${APP_RATE_LIMIT_ENABLED:true}
app.rate-limit.window-seconds=${APP_RATE_LIMIT_WINDOW_SECONDS:60}
app.rate-limit.ai.max-requests=${APP_RATE_LIMIT_AI_MAX_REQUESTS:30}
app.rate-limit.auth.max-requests=${APP_RATE_LIMIT_AUTH_MAX_REQUESTS:40}
app.rate-limit.booking-write.max-requests=${APP_RATE_LIMIT_BOOKING_WRITE_MAX_REQUESTS:30}
sepay.api-token=${SEPAY_API_TOKEN:}
sepay.account-number=${SEPAY_ACCOUNT_NUMBER:}
