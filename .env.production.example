# Copy this file to .env.production or to your hosting provider variables.
# Do not commit real secrets.

# Public URLs
VITE_API_BASE_URL=https://api.vivugo.example.com/api/
CORS_ALLOWED_ORIGIN_PATTERNS=https://vivugo.example.com,https://admin.vivugo.example.com

# Host ports for docker-compose.prod.yaml
BACKEND_PORT=8081
CLIENT_PORT=80
ADMIN_PORT=8080

# Backend runtime
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8081
HIBERNATE_DDL_AUTO=update
JPA_SHOW_SQL=false

# PostgreSQL
DB_URL=jdbc:postgresql://<host>:5432/vivugo_db?sslmode=require
DB_USERNAME=<database-user>
DB_PASSWORD=<database-password>

# JWT - use long random values, at least 32 characters
JWT_SECRET_KEY=<long-random-secret>
JWT_CUSTOMER_SECRET_KEY=<long-random-customer-secret>
JWT_ADMIN_SECRET_KEY=<long-random-admin-secret>
JWT_EXPIRATION_MS=86400000

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=<gmail-address>
MAIL_PASSWORD=<gmail-app-password>
# Railway blocks outbound SMTP on some plans. Use one HTTPS provider for production email.
# Brevo is recommended here because it can send transactional emails through HTTPS API.
BREVO_API_KEY=<brevo-transactional-api-key>
# Or use Resend instead of Brevo:
# RESEND_API_KEY=<resend-api-key>
# RESEND_FROM=ViVuGo <booking@your-verified-domain.com>
MAIL_FROM_EMAIL=<verified-sender-email>
MAIL_FROM_NAME=ViVuGo

# AI chat
AI_API_KEY=<openrouter-api-key>
AI_MODEL=openai/gpt-4o-mini

# Optional CLI deploy variables
# Required when deploying Railway from a non-interactive terminal.
RAILWAY_TOKEN=<railway-account-or-project-token>
RAILWAY_BACKEND_SERVICE=vivugo-backend
RAILWAY_BACKEND_URL=https://<backend-domain>/api/

# Optional for GitLab CI. Local Vercel CLI can use an existing browser login instead.
VERCEL_TOKEN=<vercel-token>
VERCEL_ORG_ID=<vercel-team-or-user-id>
VERCEL_CLIENT_PROJECT_ID=<vercel-client-project-id>
VERCEL_ADMIN_PROJECT_ID=<vercel-admin-project-id>
VITE_CLIENT_URL=https://<client-domain>
VITE_ADMIN_URL=https://<admin-domain>
